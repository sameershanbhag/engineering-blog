# Copy to .env.local and fill in. Generate a secret with: npx auth secret
AUTH_SECRET=

# --- OAuth providers (optional) ---
# When unset, the GitHub/Google buttons are hidden; email auth still works.
# GitHub:  https://github.com/settings/developers
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Google:  https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI:    http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Separate backend (content + real auth) ---
# Unset = in-repo mock fallback (email auth accepts any valid-looking creds in dev).
NEXT_PUBLIC_API_URL=
